#!/usr/bin/env bash
# claude-tmux — tmux session manager for Claude Code
# https://github.com/RajMishraa/claude-tmux

set -euo pipefail

VERSION="0.2.0"
SESSIONS_DIR="${HOME}/.claude-tmux"
SESSIONS_FILE="${SESSIONS_DIR}/sessions.json"
SCRIPTS_DIR="${SESSIONS_DIR}/scripts"

# ── dependency checks ─────────────────────────────────────────────────────────

command -v tmux >/dev/null 2>&1 || {
  echo "Error: tmux is not installed." >&2
  echo "  macOS:  brew install tmux" >&2
  echo "  Debian: apt install tmux" >&2
  exit 1
}
command -v python3 >/dev/null 2>&1 || {
  echo "Error: python3 is required but not found on PATH." >&2
  exit 1
}

# ── helpers ───────────────────────────────────────────────────────────────────

_ensure_registry() {
  mkdir -p "$SESSIONS_DIR" "$SCRIPTS_DIR"
  if [[ ! -f "$SESSIONS_FILE" ]]; then
    echo '{"sessions":[]}' > "$SESSIONS_FILE"
  fi
}

_validate_name() {
  local name="$1"
  [[ -n "$name" ]] || { echo "Error: session name cannot be empty." >&2; exit 1; }
  [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || {
    echo "Error: invalid session name '${name}'." >&2
    echo "       Use only letters, numbers, hyphens, and underscores." >&2
    exit 1
  }
}

_tmux_session_exists() {
  tmux has-session -t "$1" 2>/dev/null
}

_generate_uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    python3 -c "import uuid; print(str(uuid.uuid4()))"
  fi
}

# Atomic JSON write: writes to a temp file then renames into place.
_json_write() {
  local path="$1"
  local tmp="${path}.tmp.$$"
  python3 - "$path" "$tmp" "${@:2}" <<'PYEOF'
import json, sys, os

path, tmp = sys.argv[1], sys.argv[2]
args = sys.argv[3:]

with open(path) as f:
    data = json.load(f)

op = args[0]

if op == "register":
    name, cwd, ts, session_id = args[1], args[2], args[3], args[4]
    data["sessions"] = [s for s in data["sessions"] if s["name"] != name]
    data["sessions"].append({
        "name": name,
        "session_id": session_id,
        "cwd": cwd,
        "created_at": ts,
        "status": "active"
    })

elif op == "status":
    name, status = args[1], args[2]
    for s in data["sessions"]:
        if s["name"] == name:
            s["status"] = status
            break

with open(tmp, "w") as f:
    json.dump(data, f, indent=2)
os.replace(tmp, path)
PYEOF
}

_register_session() {
  local name="$1" cwd="$2" session_id="$3"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  _json_write "$SESSIONS_FILE" register "$name" "$cwd" "$ts" "$session_id"
}

_update_session_status() {
  local name="$1" status="$2"
  _json_write "$SESSIONS_FILE" status "$name" "$status"
}

# Write a startup script for a tmux session.
# Using a file avoids all send-keys timing issues and quoting problems.
_write_startup_script() {
  local name="$1" session_id="$2" cwd="$3"
  shift 3
  local extra_args=("$@")
  local script="${SCRIPTS_DIR}/${name}.sh"

  {
    echo "#!/usr/bin/env bash"
    printf 'cd %q 2>/dev/null || cd %q\n' "$cwd" "$HOME"
    printf 'claude --name %q --session-id %q --dangerously-skip-permissions' "$name" "$session_id"
    for arg in "${extra_args[@]}"; do
      printf ' %q' "$arg"
    done
    echo ""
    # Keep the window alive after claude exits so the user can inspect or restart
    echo 'echo ""'
    echo 'echo "claude exited. Type '\''exit'\'' to close this window."'
    echo 'exec bash -l'
  } > "$script"
  chmod +x "$script"
  echo "$script"
}

_usage() {
  cat <<EOF
claude-tmux v${VERSION} — tmux session manager for Claude Code
https://github.com/RajMishraa/claude-tmux

Usage:
  claude-tmux new -s <name> [-- <claude-args...>]   Create & attach new session
  claude-tmux attach -s <name>                       Attach to existing session
  claude-tmux ls                                     List all sessions
  claude-tmux restore                                Restore active sessions (runs at login)
  claude-tmux kill -s <name>                         Kill a session
  claude-tmux version                                Print version

Examples:
  claude-tmux new -s uan-project
  claude-tmux new -s uan-project -- --model opus
  claude-tmux attach -s uan-project
  claude-tmux ls
  claude-tmux kill -s uan-project
EOF
}

# ── subcommands ───────────────────────────────────────────────────────────────

cmd_new() {
  local name="" extra_args=()
  local parsing_claude_args=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      --) parsing_claude_args=true; shift ;;
      *)
        if $parsing_claude_args; then
          extra_args+=("$1")
        else
          echo "Error: unknown option '$1'" >&2; exit 1
        fi
        shift ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"
  _ensure_registry

  if _tmux_session_exists "$name"; then
    echo "Session '$name' already running — attaching."
    tmux attach-session -t "$name"
    return
  fi

  local cwd="$PWD"
  local session_id
  session_id=$(_generate_uuid)

  _register_session "$name" "$cwd" "$session_id"

  local startup
  startup=$(_write_startup_script "$name" "$session_id" "$cwd" "${extra_args[@]+"${extra_args[@]}"}")

  tmux new-session -d -s "$name" -c "$cwd" "$startup"
  tmux rename-window -t "${name}:0" "claude:${name}"

  echo "Started claude-tmux session: $name"
  echo "  Session ID  : $session_id"
  echo "  Working dir : $cwd"
  echo "  Resume cmd  : claude-tmux attach -s $name"
  echo ""

  tmux attach-session -t "$name"
}

cmd_attach() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      *) echo "Error: unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"

  if _tmux_session_exists "$name"; then
    tmux attach-session -t "$name"
  else
    echo "Session '$name' is not running."
    read -r -p "Restore it? [y/N] " ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      _restore_single "$name" && tmux attach-session -t "$name"
    fi
  fi
}

cmd_ls() {
  _ensure_registry

  local live_sessions=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && live_sessions+=("$line")
  done < <(tmux ls -F "#{session_name}" 2>/dev/null || true)

  python3 - "$SESSIONS_FILE" "${live_sessions[*]:-}" <<'PYEOF'
import json, sys

path = sys.argv[1]
live = set(sys.argv[2].split()) if len(sys.argv) > 2 and sys.argv[2] else set()

with open(path) as f:
    data = json.load(f)

sessions = data.get("sessions", [])
if not sessions:
    print("No sessions registered.")
    sys.exit(0)

print(f"{'NAME':<22} {'STATE':<10} {'CREATED':<22} {'SESSION ID':<36} CWD")
print("-" * 110)
for s in sessions:
    name      = s["name"]
    reg_status = s.get("status", "unknown")
    state     = "[live]" if name in live else f"[{reg_status}]"
    created   = s.get("created_at", "")[:19].replace("T", " ")
    sid       = s.get("session_id", "n/a")
    cwd       = s.get("cwd", "")
    print(f"{name:<22} {state:<10} {created:<22} {sid:<36} {cwd}")
PYEOF
}

_restore_single() {
  local name="$1"
  _ensure_registry

  local info
  info=$(python3 - "$SESSIONS_FILE" "$name" <<'PYEOF'
import json, sys
path, name = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
for s in data["sessions"]:
    if s["name"] == name and s.get("status") == "active":
        print(s.get("session_id", ""))
        print(s.get("cwd", ""))
        sys.exit(0)
print("")
print("")
sys.exit(1)
PYEOF
) || { echo "No active session named '$name' found in registry." >&2; return 1; }

  local session_id cwd
  session_id=$(echo "$info" | sed -n '1p')
  cwd=$(echo "$info" | sed -n '2p')

  [[ -d "$cwd" ]] || cwd="$HOME"

  local startup
  startup=$(_write_startup_script "$name" "$session_id" "$cwd")

  # Update startup script to use --resume so conversation history is picked up
  {
    echo "#!/usr/bin/env bash"
    printf 'cd %q 2>/dev/null || cd %q\n' "$cwd" "$HOME"
    printf 'claude --resume %q --dangerously-skip-permissions\n' "$session_id"
    echo 'echo ""'
    echo 'echo "claude exited. Type '\''exit'\'' to close this window."'
    echo 'exec bash -l'
  } > "$startup"
  chmod +x "$startup"

  tmux new-session -d -s "$name" -c "$cwd" "$startup"
  tmux rename-window -t "${name}:0" "claude:${name}"
  echo "Restored session: $name (id: $session_id, cwd: $cwd)"
}

cmd_restore() {
  _ensure_registry

  local names=()
  while IFS= read -r n; do
    [[ -n "$n" ]] && names+=("$n")
  done < <(python3 - "$SESSIONS_FILE" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
for s in data.get("sessions", []):
    if s.get("status") == "active":
        print(s["name"])
PYEOF
)

  if [[ ${#names[@]} -eq 0 ]]; then
    echo "No active sessions to restore."
    return
  fi

  for name in "${names[@]}"; do
    if _tmux_session_exists "$name"; then
      echo "Session '$name' already running — skipping."
    else
      _restore_single "$name" || true
    fi
  done
}

cmd_kill() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      *) echo "Error: unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"
  _ensure_registry

  if _tmux_session_exists "$name"; then
    tmux kill-session -t "$name"
    echo "Killed tmux session: $name"
  else
    echo "Session '$name' is not running (marking killed in registry anyway)."
  fi

  _update_session_status "$name" "killed"
  echo "Marked as killed in registry."
}

# ── entrypoint ────────────────────────────────────────────────────────────────

[[ $# -eq 0 ]] && { _usage; exit 0; }

subcmd="$1"; shift

case "$subcmd" in
  new)           cmd_new "$@" ;;
  attach)        cmd_attach "$@" ;;
  ls)            cmd_ls ;;
  restore)       cmd_restore ;;
  kill)          cmd_kill "$@" ;;
  version|--version|-v) echo "claude-tmux v${VERSION}" ;;
  help|-h|--help) _usage ;;
  *) echo "Error: unknown subcommand '${subcmd}'" >&2; _usage; exit 1 ;;
esac
