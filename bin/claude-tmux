#!/usr/bin/env bash
# claude-tmux — tmux session manager for Claude Code
# https://github.com/RajMishraa/claude-tmux

set -euo pipefail

VERSION="0.8.2"
GITHUB_RAW="https://raw.githubusercontent.com/RajMishraa/claude-tmux/main"
SESSIONS_DIR="${HOME}/.claude-tmux"
SESSIONS_FILE="${SESSIONS_DIR}/sessions.json"
SCRIPTS_DIR="${SESSIONS_DIR}/scripts"

# ── dependency checks ─────────────────────────────────────────────────────────

command -v tmux >/dev/null 2>&1 || {
  echo "Error: tmux is not installed." >&2
  echo "  macOS:  brew install tmux" >&2
  echo "  Debian: sudo apt install tmux" >&2
  exit 1
}
command -v python3 >/dev/null 2>&1 || {
  echo "Error: python3 is required but not found on PATH." >&2
  exit 1
}

# ── helpers ───────────────────────────────────────────────────────────────────

_ensure_registry() {
  mkdir -p "$SESSIONS_DIR" "$SCRIPTS_DIR"
  if [[ ! -f "$SESSIONS_FILE" ]]; then
    echo '{"sessions":[]}' > "$SESSIONS_FILE"
  fi
}

_validate_name() {
  local name="$1"
  [[ -n "$name" ]] || { echo "Error: session name cannot be empty." >&2; exit 1; }
  [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || {
    echo "Error: invalid session name '${name}'." >&2
    echo "       Use only letters, numbers, hyphens, and underscores." >&2
    exit 1
  }
}

_tmux_session_exists() {
  tmux has-session -t "$1" 2>/dev/null
}

_generate_uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    python3 -c "import uuid; print(str(uuid.uuid4()))"
  fi
}

# Resolve full path to the claude binary so startup scripts work regardless
# of PATH in the tmux environment (e.g. during launchd restore).
_claude_bin() {
  command -v claude 2>/dev/null || {
    echo "Error: claude CLI not found on PATH." >&2
    echo "       Install Claude Code: https://claude.ai/code" >&2
    exit 1
  }
}

# Atomic JSON write: write to a temp file then rename into place.
_json_write() {
  local path="$1"
  local tmp="${path}.tmp.$$"
  python3 - "$path" "$tmp" "${@:2}" <<'PYEOF'
import json, sys, os

path, tmp = sys.argv[1], sys.argv[2]
args = sys.argv[3:]

with open(path) as f:
    data = json.load(f)

op = args[0]

if op == "register":
    # argv: name cwd ts session_id tags_csv jira [extra_arg ...]
    name, cwd, ts, session_id, tags_csv, jira = args[1], args[2], args[3], args[4], args[5], args[6]
    extra = args[7:]
    data["sessions"] = [s for s in data["sessions"] if s["name"] != name]
    entry = {
        "name": name,
        "session_id": session_id,
        "cwd": cwd,
        "created_at": ts,
        "status": "active",
    }
    if tags_csv:
        entry["tags"] = [t.strip() for t in tags_csv.split(",") if t.strip()]
    if jira:
        entry["jira"] = jira
    if extra:
        entry["args"] = extra
    data["sessions"].append(entry)

elif op == "status":
    name, status = args[1], args[2]
    for s in data["sessions"]:
        if s["name"] == name:
            s["status"] = status
            break

elif op == "url":
    name, url = args[1], args[2]
    for s in data["sessions"]:
        if s["name"] == name:
            s["url"] = url
            break

elif op == "jira":
    name, jira = args[1], args[2]
    for s in data["sessions"]:
        if s["name"] == name:
            s["jira"] = jira
            break

with open(tmp, "w") as f:
    json.dump(data, f, indent=2)
os.replace(tmp, path)
PYEOF
}

_register_session() {
  # _register_session <name> <cwd> <session_id> <tag> <jira> [extra_args...]
  local name="$1" cwd="$2" session_id="$3" tag="${4:-}" jira="${5:-}"
  shift 5 2>/dev/null || shift $#
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  _json_write "$SESSIONS_FILE" register "$name" "$cwd" "$ts" "$session_id" "$tag" "$jira" "$@"
}

_update_session_status() {
  _json_write "$SESSIONS_FILE" status "$1" "$2"
}

_set_session_url() {
  _json_write "$SESSIONS_FILE" url "$1" "$2"
}

_set_session_jira() {
  _json_write "$SESSIONS_FILE" jira "$1" "$2"
}

_get_session_jira() {
  python3 - "$SESSIONS_FILE" "$1" <<'PYEOF'
import json, sys
path, name = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
for s in data["sessions"]:
    if s["name"] == name:
        jira = s.get("jira", "")
        if jira:
            print(jira)
        sys.exit(0)
sys.exit(1)
PYEOF
}

# Capture URL from tmux pane output.
_capture_url() {
  local name="$1"
  tmux capture-pane -t "$name" -p 2>/dev/null | grep -oE 'https://[^ ]+' | tail -1 || true
}

# Read stored URL from registry.
_get_session_url() {
  python3 - "$SESSIONS_FILE" "$1" <<'PYEOF'
import json, sys
path, name = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
for s in data["sessions"]:
    if s["name"] == name:
        url = s.get("url", "")
        if url:
            print(url)
        sys.exit(0)
sys.exit(1)
PYEOF
}

# Write a startup script for a new session (uses --session-id).
# Hardcodes the claude binary path so launchd restores work without PATH setup.
# Extra args (e.g. --dangerously-skip-permissions) are passed through as-is.
# If jira is set, injects --append-system-prompt so Claude knows the ticket.
_write_new_script() {
  local name="$1" session_id="$2" cwd="$3" claude_bin="$4" jira="${5:-}"
  shift 5 2>/dev/null || shift 4
  local extra_args=("$@")
  local script="${SCRIPTS_DIR}/${name}.sh"

  {
    echo "#!/usr/bin/env bash"
    printf 'cd %q 2>/dev/null || cd %q\n' "$cwd" "$HOME"
    printf '%q --name %q --session-id %q' "$claude_bin" "$name" "$session_id"
    if [[ -n "$jira" ]]; then
      printf ' --append-system-prompt %q' \
        "You are working on JIRA ticket ${jira}. At the start of this session, use the Atlassian MCP tools to fetch the ticket details (summary, description, status, comments) so you have full context. Track your progress and be ready to provide a status update when the user runs /tmux-update-jira."
    fi
    for arg in "${extra_args[@]}"; do
      printf ' %q' "$arg"
    done
    echo ""
    echo 'echo ""'
    echo 'echo "claude exited. Type '\''exit'\'' to close this window."'
    echo 'exec bash -l'
  } > "$script"
  chmod +x "$script"
  echo "$script"
}

# Write a restore script for an existing session (uses --resume <uuid>).
# Falls back to a fresh session when uuid is missing (pre-0.2.0 sessions).
# Replays the original extra args stored in the registry.
_write_restore_script() {
  local name="$1" session_id="$2" cwd="$3" claude_bin="$4" jira="${5:-}"
  shift 5 2>/dev/null || shift 4
  local extra_args=("$@")
  local script="${SCRIPTS_DIR}/${name}.sh"

  {
    echo "#!/usr/bin/env bash"
    printf 'cd %q 2>/dev/null || cd %q\n' "$cwd" "$HOME"
    if [[ -n "$session_id" ]]; then
      printf '%q --resume %q' "$claude_bin" "$session_id"
    else
      printf '%q --name %q' "$claude_bin" "$name"
    fi
    if [[ -n "$jira" ]]; then
      printf ' --append-system-prompt %q' \
        "You are working on JIRA ticket ${jira}. Use the Atlassian MCP tools to check the ticket status when needed."
    fi
    for arg in "${extra_args[@]}"; do
      printf ' %q' "$arg"
    done
    echo ""
    echo 'echo ""'
    echo 'echo "claude exited. Type '\''exit'\'' to close this window."'
    echo 'exec bash -l'
  } > "$script"
  chmod +x "$script"
  echo "$script"
}

_usage() {
  cat <<EOF
claude-tmux v${VERSION} — tmux session manager for Claude Code
https://github.com/RajMishraa/claude-tmux

Usage:
  claude-tmux new -s <name> [--tag <t1,t2>] [--jira <PROJ-123>] [<claude-args...>]
                                                 Create & attach new session
  claude-tmux attach -s <name>                   Attach to existing session
  claude-tmux ls [--tag <group>]                 List all sessions (optionally filter by tag)
  claude-tmux jira -s <name> [TICKET-ID]          Get/set JIRA ticket for a session
  claude-tmux url -s <name>                      Show/refresh session URL
  claude-tmux restore                            Restore active sessions (runs at login)
  claude-tmux kill -s <name>                     Kill a session
  claude-tmux upgrade                            Upgrade to the latest version
  claude-tmux version                            Print version

Examples:
  claude-tmux new -s uan-project
  claude-tmux new -s ticket-triage --tag jira --jira PROJ-123
  claude-tmux new -s api-refactor --tag dev --jira PROJ-456
  claude-tmux ls --tag jira
  claude-tmux url -s uan-project
  claude-tmux ls
  claude-tmux kill -s uan-project

Multi-agent skills (run inside any Claude session):
  /tmux-team-create    Spin up a team of agents from JIRA tickets or task descriptions
  /tmux-team-status    Show progress of all agents in a group
  /tmux-team-sync      Cross-pollinate context between agents
  /tmux-plan           Read a JIRA Epic and generate a Work Breakdown Structure
  /tmux-handoff        Transfer work context to another agent session
  /tmux-review         Review work done by another agent session
  /tmux-update-jira    Post progress update to the linked JIRA ticket
  /tmux-pick-ticket    Search and pick an open JIRA ticket
  /tmux-link-jira      Link this session to a JIRA ticket
EOF
}

# ── subcommands ───────────────────────────────────────────────────────────────

cmd_new() {
  local name="" jira="" extra_args=()
  local -a tags=()

  # -s/--session, --tag, and --jira are consumed by claude-tmux.
  # All other args are passed directly to claude.
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      --tag)        tags+=("$2"); shift 2 ;;
      --jira)       jira="$2"; shift 2 ;;
      *)            extra_args+=("$1"); shift ;;
    esac
  done

  # Join all tags into a single comma-separated string
  local tag=""
  if [[ ${#tags[@]} -gt 0 ]]; then
    tag=$(IFS=,; echo "${tags[*]}")
  fi

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"
  _ensure_registry

  if _tmux_session_exists "$name"; then
    echo "Session '$name' already running — attaching."
    tmux attach-session -t "$name"
    return
  fi

  local cwd="$PWD"
  local session_id claude_bin
  session_id=$(_generate_uuid)
  claude_bin=$(_claude_bin)

  _register_session "$name" "$cwd" "$session_id" "$tag" "$jira" "${extra_args[@]+"${extra_args[@]}"}"

  local startup
  startup=$(_write_new_script "$name" "$session_id" "$cwd" "$claude_bin" "$jira" \
    "${extra_args[@]+"${extra_args[@]}"}")

  tmux new-session -d -s "$name" -c "$cwd" "$startup"
  tmux rename-window -t "${name}:0" "claude:${name}" || true

  echo "Started claude-tmux session: $name"
  echo "  Session ID  : $session_id"
  echo "  Working dir : $cwd"
  [[ -n "$tag" ]] && echo "  Tags        : $tag"
  [[ -n "$jira" ]] && echo "  JIRA        : $jira"
  echo "  Resume cmd  : claude-tmux attach -s $name"

  # Auto-capture remote URL (Claude prints it on startup if remote access is on)
  echo "  Waiting for remote URL..."
  sleep 5
  local url
  url=$(_capture_url "$name")
  if [[ -n "$url" ]]; then
    _set_session_url "$name" "$url"
    echo "  URL         : $url"
  else
    echo "  URL         : (not detected — run 'claude-tmux url -s $name' later)"
  fi
  echo ""

  tmux attach-session -t "$name"
}

cmd_attach() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      *) echo "Error: unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"

  if _tmux_session_exists "$name"; then
    tmux attach-session -t "$name"
  else
    echo "Session '$name' is not running."
    if [[ -t 0 ]]; then
      read -r -p "Restore it? [y/N] " ans
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        _restore_single "$name" && tmux attach-session -t "$name"
      fi
    else
      echo "Run 'claude-tmux restore' to restore it." >&2
    fi
  fi
}

cmd_url() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      *) echo "Error: unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"
  _ensure_registry

  # Try to refresh from tmux pane if session is live
  if _tmux_session_exists "$name"; then
    local captured
    captured=$(_capture_url "$name")
    if [[ -n "$captured" ]]; then
      _set_session_url "$name" "$captured"
    fi
  fi

  # Print stored URL
  local url
  url=$(_get_session_url "$name") || {
    echo "No URL stored for session '$name'." >&2
    echo "If remote access is on, run this inside the session first, then try again." >&2
    exit 1
  }
  if [[ -n "$url" ]]; then
    echo "$url"
  else
    echo "No URL stored for session '$name'." >&2
    exit 1
  fi
}

cmd_jira() {
  local name="" ticket=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      -*) echo "Error: unknown option '$1'" >&2; exit 1 ;;
      *)  ticket="$1"; shift ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"
  _ensure_registry

  if [[ -n "$ticket" ]]; then
    # Set mode
    _set_session_jira "$name" "$ticket"
    echo "Linked session '$name' to JIRA ticket: $ticket"
  else
    # Get mode
    local jira
    jira=$(_get_session_jira "$name") || {
      echo "No JIRA ticket linked to session '$name'." >&2
      exit 1
    }
    if [[ -n "$jira" ]]; then
      echo "$jira"
    else
      echo "No JIRA ticket linked to session '$name'." >&2
      exit 1
    fi
  fi
}

cmd_ls() {
  local filter_tag=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tag) filter_tag="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  _ensure_registry

  local live_sessions=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && live_sessions+=("$line")
  done < <(tmux ls -F "#{session_name}" 2>/dev/null || true)

  python3 - "$SESSIONS_FILE" "${live_sessions[*]:-}" "$filter_tag" <<'PYEOF'
import json, sys

path = sys.argv[1]
live = set(sys.argv[2].split()) if len(sys.argv) > 2 and sys.argv[2] else set()
filter_tag = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else ""

with open(path) as f:
    data = json.load(f)

sessions = data.get("sessions", [])

# Migrate legacy "tag" string to "tags" array
for s in sessions:
    if "tag" in s and "tags" not in s:
        old = s.pop("tag")
        s["tags"] = [old] if old else []

if filter_tag:
    sessions = [s for s in sessions if filter_tag in s.get("tags", [])]

if not sessions:
    if filter_tag:
        print(f"No sessions with tag '{filter_tag}'.")
    else:
        print("No sessions registered.")
    sys.exit(0)

has_tags = any(s.get("tags") for s in sessions)
has_jira = any(s.get("jira") for s in sessions)
has_urls = any(s.get("url") for s in sessions)

header_parts = [f"{'NAME':<22}", f"{'STATE':<10}"]
if has_tags:
    header_parts.append(f"{'TAGS':<16}")
if has_jira:
    header_parts.append(f"{'JIRA':<14}")
header_parts.append(f"{'CREATED':<22}")
if has_urls:
    header_parts.append("URL")
else:
    header_parts.append("CWD")
print(" ".join(header_parts))
print("-" * 120)

for s in sessions:
    name       = s["name"]
    reg_status = s.get("status", "unknown")
    state      = "[live]" if name in live else f"[{reg_status}]"
    tags       = ",".join(s.get("tags", []))
    jira       = s.get("jira", "")
    created    = s.get("created_at", "")[:19].replace("T", " ")
    parts = [f"{name:<22}", f"{state:<10}"]
    if has_tags:
        parts.append(f"{tags:<16}")
    if has_jira:
        parts.append(f"{jira:<14}")
    parts.append(f"{created:<22}")
    if has_urls:
        parts.append(s.get("url", ""))
    else:
        parts.append(s.get("cwd", ""))
    print(" ".join(parts))
PYEOF
}

_restore_single() {
  local name="$1"
  _ensure_registry

  # Output: line1=session_id, line2=cwd, line3=jira, lines4+=stored args
  local info
  info=$(python3 - "$SESSIONS_FILE" "$name" <<'PYEOF'
import json, sys
path, name = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
for s in data["sessions"]:
    if s["name"] == name and s.get("status") == "active":
        print(s.get("session_id", ""))
        print(s.get("cwd", ""))
        print(s.get("jira", ""))
        for arg in s.get("args", []):
            print(arg)
        sys.exit(0)
print("")
print("")
print("")
sys.exit(1)
PYEOF
) || { echo "No active session named '$name' found in registry." >&2; return 1; }

  local session_id cwd jira
  session_id=$(echo "$info" | sed -n '1p')
  cwd=$(echo "$info" | sed -n '2p')
  jira=$(echo "$info" | sed -n '3p')
  [[ -d "$cwd" ]] || cwd="$HOME"

  # Read stored args (lines 4+)
  local extra_args=()
  while IFS= read -r arg; do
    [[ -n "$arg" ]] && extra_args+=("$arg")
  done < <(echo "$info" | tail -n +4)

  local claude_bin
  claude_bin=$(_claude_bin)

  local startup
  startup=$(_write_restore_script "$name" "$session_id" "$cwd" "$claude_bin" "$jira" \
    "${extra_args[@]+"${extra_args[@]}"}")

  tmux new-session -d -s "$name" -c "$cwd" "$startup"
  tmux rename-window -t "${name}:0" "claude:${name}" || true
  echo "Restored session: $name (id: ${session_id:-n/a}, cwd: $cwd)"
}

cmd_restore() {
  _ensure_registry

  local names=()
  while IFS= read -r n; do
    [[ -n "$n" ]] && names+=("$n")
  done < <(python3 - "$SESSIONS_FILE" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
for s in data.get("sessions", []):
    if s.get("status") == "active":
        print(s["name"])
PYEOF
)

  if [[ ${#names[@]} -eq 0 ]]; then
    echo "No active sessions to restore."
    return
  fi

  for name in "${names[@]}"; do
    if _tmux_session_exists "$name"; then
      echo "Session '$name' already running — skipping."
    else
      _restore_single "$name" || true
    fi
  done
}

cmd_kill() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--session) name="$2"; shift 2 ;;
      *) echo "Error: unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Error: -s <name> is required" >&2; exit 1; }
  _validate_name "$name"
  _ensure_registry

  if _tmux_session_exists "$name"; then
    tmux kill-session -t "$name"
    echo "Killed tmux session: $name"
  else
    echo "Session '$name' is not running (marking killed in registry anyway)."
  fi

  _update_session_status "$name" "killed"
  echo "Marked as killed in registry."
}

cmd_upgrade() {
  local bin_target
  bin_target="$(command -v claude-tmux 2>/dev/null || echo "${HOME}/.local/bin/claude-tmux")"
  local skills_dir="${HOME}/.claude/skills"

  echo "Upgrading claude-tmux..."
  echo "  Current version: v${VERSION}"

  # Download latest binary
  local tmp
  tmp=$(mktemp)
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${GITHUB_RAW}/bin/claude-tmux" -o "$tmp"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$tmp" "${GITHUB_RAW}/bin/claude-tmux"
  else
    echo "Error: curl or wget is required." >&2
    rm -f "$tmp"
    exit 1
  fi

  # Extract new version
  local new_version
  new_version=$(grep -m1 '^VERSION=' "$tmp" | cut -d'"' -f2)

  if [[ -z "$new_version" ]]; then
    echo "Error: downloaded file does not look like claude-tmux." >&2
    rm -f "$tmp"
    exit 1
  fi

  if [[ "$new_version" == "$VERSION" ]]; then
    echo "  Already up to date (v${VERSION})."
    rm -f "$tmp"
    return
  fi

  # Replace binary
  mv "$tmp" "$bin_target"
  chmod +x "$bin_target"
  echo "  ✓ Binary updated → v${new_version}"

  # Update skills — fetch skill list from remote install.sh so future skills
  # are always discovered even when upgrading from an older binary.
  local remote_skills=""
  if command -v curl >/dev/null 2>&1; then
    remote_skills=$(curl -fsSL "${GITHUB_RAW}/install.sh" 2>/dev/null \
      | grep '^ALL_SKILLS=' | head -1 | cut -d'"' -f2)
  elif command -v wget >/dev/null 2>&1; then
    remote_skills=$(wget -qO- "${GITHUB_RAW}/install.sh" 2>/dev/null \
      | grep '^ALL_SKILLS=' | head -1 | cut -d'"' -f2)
  fi
  # Fallback to known list if remote install.sh couldn't be fetched
  if [[ -z "$remote_skills" ]]; then
    remote_skills="tmux-new tmux-ls tmux-kill tmux-attach tmux-update-jira tmux-pick-ticket tmux-link-jira tmux-team-create tmux-team-status tmux-team-sync tmux-plan tmux-handoff tmux-review"
  fi

  local updated_skills=0
  for skill_name in $remote_skills; do
    mkdir -p "${skills_dir}/${skill_name}"
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "${GITHUB_RAW}/skills/${skill_name}/SKILL.md" \
        -o "${skills_dir}/${skill_name}/SKILL.md" 2>/dev/null && updated_skills=$((updated_skills + 1))
    elif command -v wget >/dev/null 2>&1; then
      wget -qO "${skills_dir}/${skill_name}/SKILL.md" \
        "${GITHUB_RAW}/skills/${skill_name}/SKILL.md" 2>/dev/null && updated_skills=$((updated_skills + 1))
    fi
  done

  if [[ $updated_skills -gt 0 ]]; then
    echo "  ✓ Updated ${updated_skills} Claude skills"
  fi

  echo ""
  echo "Upgraded: v${VERSION} → v${new_version}"
}

# ── entrypoint ────────────────────────────────────────────────────────────────

[[ $# -eq 0 ]] && { _usage; exit 0; }

subcmd="$1"; shift

case "$subcmd" in
  new)                  cmd_new "$@" ;;
  attach)               cmd_attach "$@" ;;
  ls)                   cmd_ls "$@" ;;
  jira)                 cmd_jira "$@" ;;
  url)                  cmd_url "$@" ;;
  restore)              cmd_restore ;;
  kill)                 cmd_kill "$@" ;;
  upgrade)              cmd_upgrade ;;
  version|--version|-v) echo "claude-tmux v${VERSION}" ;;
  help|-h|--help)       _usage ;;
  *) echo "Error: unknown subcommand '${subcmd}'" >&2; _usage; exit 1 ;;
esac
